---
interface ExperienceItem {
  slug: string;
  role: string;
  company: string;
  location: string;
  startDate: string;
  endDate: string;
  highlights: string[];
  stack: string[];
}

interface Props {
  title: string;
  experience: ExperienceItem[];
}

const { title, experience } = Astro.props;
---

<section class="panel" id="experience">
  <div class="section-heading">
    <h2>{title}</h2>
  </div>
  <div class="timeline">
    {experience.map((item) => (
      <article class="timeline-item">
        <div class="timeline-head">
          <h3>{item.role}</h3>
          <span class="chip">{item.startDate} - {item.endDate}</span>
        </div>
        <p class="muted">{item.company} | {item.location}</p>
        <ul>
          {item.highlights.map((line) => (
            <li>{line}</li>
          ))}
        </ul>
        <ul class="tag-list" aria-label="Experience stack tags">
          {item.stack.map((tech) => (
            <li>{tech}</li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</section>
